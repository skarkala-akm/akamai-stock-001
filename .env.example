# Akamai Stock Dashboard - Dev Environment Variables
# Copy to .env and fill in values for local development

# Application Image (placeholder; replace with real built image)
APP_IMAGE=nginxdemos/hello:plain-text

# Stock Dashboard Config
STOCK_SYMBOL=AKAM
STOCK_PROVIDER=Yahoo Finance
REFRESH_INTERVAL_SECONDS=60
PORT=3000

# Kubernetes
K8S_NAMESPACE=factory-stock-dash-dev

# GitHub
GITHUB_REPO=github.com/skarkala-akm/akamai-stock-001
